<idea-plugin>
    <id>org.apache.ofbiz.OFBizIDEAInteg</id>
    <name>OFBiz IDEA Integration</name>
    <vendor email="github@nereide.fr" url="https://www.nereide.fr/">OFBiz</vendor>

    <description><![CDATA[
    &lt;strong&gt;OFBiz&lt;/strong&gt; is the APACHE fundation free ERP.
    Strong and resilient, it is completely free to use and expand.
    This plugin aims to help you expand OFBiz for your needs.&lt;br/&gt;
    Please report any bug &lt;a href="https://github.com/Nereide-lab/idea-ofbiz-plugin/issues/new"&gt;here&lt;/a&gt; &lt;br/&gt;
    And of course, feel free to contribute !&lt;br/&gt;
    Made by Nereide
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.intellij.groovy</depends>
<!--    <depends>JavaScript</depends> Ultimate only, c'est pénible -->
    <depends config-file="ofbiz-xml-injections.xml">org.intellij.intelliLang</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Project MiscUtils for file and DomElement recuperations -->
        <projectService serviceInterface="org.apache.ofbiz.idea.plugin.project.ProjectServiceInterface"
                        serviceImplementation="org.apache.ofbiz.idea.plugin.project.ProjectServiceImpl"/>

        <!-- XML reference support -->
        <psi.referenceContributor language="XML" implementation="org.apache.ofbiz.idea.plugin.reference.contributor.XmlReferenceContributor"/>
        <completion.contributor order="first" language="XML" implementationClass="org.apache.ofbiz.idea.plugin.completion.contributor.XmlCompletionContributor"/>

        <!-- Java reference support -->
        <psi.referenceContributor language="JAVA" implementation="org.apache.ofbiz.idea.plugin.reference.contributor.JavaReferenceContributor"/>
        <completion.contributor order="first" language="JAVA" implementationClass="org.apache.ofbiz.idea.plugin.completion.contributor.JavaCompletionContributor"/>

        <!-- Groovy reference support -->
        <psi.referenceContributor language="Groovy" implementation="org.apache.ofbiz.idea.plugin.reference.contributor.GroovyReferenceContributor"/>
        <completion.contributor order="first" language="Groovy" implementationClass="org.apache.ofbiz.idea.plugin.completion.contributor.GroovyCompletionContributor"/>

        <!-- Documentation -->
        <documentationProvider implementation="org.apache.ofbiz.idea.plugin.documentation.OfbizElementResolverForDocumentationProvider" order="first"/>
        <lang.documentationProvider language="XML" implementationClass="org.apache.ofbiz.idea.plugin.documentation.OfbizXmlDocumentationProvider"/>
        <lang.documentationProvider language="JAVA" implementationClass="org.apache.ofbiz.idea.plugin.documentation.OfbizJavaDocumentationProvider"/>

        <!-- XML file description -->
        <dom.fileMetaData implementation="org.apache.ofbiz.idea.plugin.dom.ComponentFileDescription" rootTagName="ofbiz-component"/>
        <dom.fileMetaData implementation="org.apache.ofbiz.idea.plugin.dom.ControllerFileDescription" rootTagName="site-conf"/>
        <dom.fileMetaData implementation="org.apache.ofbiz.idea.plugin.dom.EntityModelFileDescription" rootTagName="entitymodel"/>
        <dom.fileMetaData implementation="org.apache.ofbiz.idea.plugin.dom.ServiceDefFileDescription" rootTagName="services"/>
        <dom.fileMetaData implementation="org.apache.ofbiz.idea.plugin.dom.UiLabelFileDescription" rootTagName="resource"/>
        <dom.fileMetaData implementation="org.apache.ofbiz.idea.plugin.dom.FormFileDescription" rootTagName="forms"/>
        <dom.fileMetaData implementation="org.apache.ofbiz.idea.plugin.dom.MenuFileDescription" rootTagName="menus"/>
        <dom.fileMetaData implementation="org.apache.ofbiz.idea.plugin.dom.ScreenFileDescription" rootTagName="screens"/>
        <dom.fileMetaData implementation="org.apache.ofbiz.idea.plugin.dom.CompoundFileDescription" rootTagName="compound-widgets"/>
        <dom.fileMetaData implementation="org.apache.ofbiz.idea.plugin.dom.EntityEngineFileDescription" rootTagName="entity-config"/>

        <!-- Code inspections -->
        <localInspection language="XML"
                         bundle="messages.InspectionBundle"
                         key="inspection.location.target.file.not.found.display.name"
                         groupPath="OFBiz"
                         groupBundle="messages.InspectionsBundle"
                         groupKey="group.names.probable.bugs"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="org.apache.ofbiz.idea.plugin.inspection.EmptyFileLocationInspection"/>
    </extensions>
</idea-plugin>