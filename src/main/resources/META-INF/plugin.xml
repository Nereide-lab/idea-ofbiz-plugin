<idea-plugin>
    <id>org.apache.ofbiz.OFBizIDEAInteg</id>
    <name>OFBiz IDEA Integration</name>
    <vendor email="github@nereide.fr" url="https://www.nereide.fr/">Néréide</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.intellij.groovy</depends>
<!--    <depends>JavaScript</depends> Ultimate only, c'est pénible -->
    <depends config-file="ofbiz-xml-injections.xml">org.intellij.intelliLang</depends>
    <depends config-file="ofbiz-completion.xml">com.intellij</depends>
    <depends config-file="ofbiz-inspections.xml">com.intellij</depends>
    <depends config-file="ofbiz-live-templates.xml">com.intellij</depends>

    <extensions defaultExtensionNs="com.intellij">

        <codeInsight.lineMarkerProvider language="JAVA" implementationClass="fr.nereide.editor.marker.java.JavaServiceEcaMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Groovy" implementationClass="fr.nereide.editor.marker.groovy.GroovyServiceEcaMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="XML" implementationClass="fr.nereide.editor.marker.xml.XmlServiceEcaMarkerProvider"/>

        <codeInsight.lineMarkerProvider language="JAVA" implementationClass="fr.nereide.editor.marker.java.JavaEntityEcaMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Groovy" implementationClass="fr.nereide.editor.marker.groovy.GroovyEntityEcaMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="XML" implementationClass="fr.nereide.editor.marker.xml.XmlEntityEcaMarkerProvider"/>

        <psi.referenceContributor language="XML" implementation="fr.nereide.reference.contributor.XmlReferenceContributor"/>
        <psi.referenceContributor language="JAVA" implementation="fr.nereide.reference.contributor.JavaReferenceContributor"/>
        <psi.referenceContributor language="Groovy" implementation="fr.nereide.reference.contributor.GroovyReferenceContributor"/>

        <!-- Documentation -->
        <documentationProvider implementation="fr.nereide.documentation.OfbizElementResolverForDocumentationProvider" order="first"/>
        <lang.documentationProvider language="XML" implementationClass="fr.nereide.documentation.OfbizXmlDocumentationProvider"/>
        <lang.documentationProvider language="JAVA" implementationClass="fr.nereide.documentation.OfbizJavaDocumentationProvider"/>

        <!-- XML file description -->
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.ComponentFileDescription" rootTagName="ofbiz-component"/>
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.ControllerFileDescription" rootTagName="site-conf"/>
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.EntityModelFileDescription" rootTagName="entitymodel"/>
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.ServiceDefFileDescription" rootTagName="services"/>
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.UiLabelFileDescription" rootTagName="resource"/>
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.FormFileDescription" rootTagName="forms"/>
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.MenuFileDescription" rootTagName="menus"/>
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.ScreenFileDescription" rootTagName="screens"/>
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.CompoundFileDescription" rootTagName="compound-widgets"/>
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.EntityEngineFileDescription" rootTagName="entity-config"/>
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.ServiceEcaFileDescription" rootTagName="service-eca"/>
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.EntityEcaFileDescription" rootTagName="entity-eca"/>
        <dom.fileMetaData implementation="fr.nereide.dom.filedesc.ServiceEngineFileDescription" rootTagName="service-config"/>
    </extensions>
</idea-plugin>
